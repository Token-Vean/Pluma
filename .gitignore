# =============================================================================
# Datos de prueba — IMPORTANTE
# -----------------------------------------------------------------------------
# Documentos reales que se usen para probar la aplicación nunca deben
# subirse al repo, especialmente si pueden contener datos personales o
# de instituciones reales. Se ignora cualquier documento dentro de
# /ejemplos salvo el README. Si quieres añadir ejemplos públicos al
# repositorio (de dominio público), añádelos con `git add -f`.
# =============================================================================
ejemplos/*
!ejemplos/README.md
!ejemplos/*.md

# Carpetas comunes de pruebas locales
/tmp/
/uploads_local/
/pruebas/
/test_documents/
/documentos_prueba/

# Patrones por nombre
*.test.pdf
*.test.docx
*.test.jpg
*.test.png

# =============================================================================
# Outputs locales (logs, escaneos, exports manuales)
# =============================================================================
*.tmp
*.bak
trivy-results.*
pip-audit-results.*
*.local.log
audit_*.txt
audit_*.json

# Si exportas propuestas a fichero durante las pruebas, no se suben
exports/
salidas/

# =============================================================================
# Modelos Ollama (no van al repo)
# =============================================================================
ollama-models/
*.gguf
*.bin

# =============================================================================
