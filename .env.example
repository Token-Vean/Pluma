# =============================================================================
# PlumA — configuración pública segura
# -----------------------------------------------------------------------------
# Esta release está bloqueada para uso local. No expone opciones para conectar
# endpoints remotos ni para publicar la aplicación en red.
#
# La aplicación fuerza internamente:
#   PLUMA_STRICT_LOCAL=true
#   OLLAMA_URL=http://ollama:11434
#   ALLOW_REMOTE_OLLAMA=false
#   ALLOW_NETWORK_EXPOSURE=false
#
# La interfaz web se publica de forma fija en:
#   http://localhost:8082
#   127.0.0.1:8082 -> contenedor app:8081
#
# No añada OLLAMA_URL, ALLOW_REMOTE_OLLAMA, ALLOW_NETWORK_EXPOSURE,
# COMPOSE_PROFILES ni PERFIL a este archivo. Los scripts de instalación los
# eliminarán si aparecen por herencia de versiones anteriores.
# =============================================================================

# Modelo base que Ollama descargará si no existe ya en el volumen local.
MODELO_BASE=gemma4:e2b

# Nombre interno del modelo especializado creado desde Modelfile.
MODELO_NOMBRE=pluma:0.4.16

# Límites de análisis documental.
USAR_SANDBOX_PARSERS=true
SANDBOX_TIMEOUT_SEGUNDOS=90
SANDBOX_MEMORIA_MB=1536
MAX_LONGITUD_TEXTO_EXTRAIDO=800000

# Opciones de salida del modelo.
OLLAMA_NUM_CTX=32768
OLLAMA_NUM_PREDICT=8192
MAX_LONGITUD_VALOR_LLM=50000
MAX_LONGITUD_EVIDENCIA_LLM=4000
MAX_LONGITUD_ITEM_LISTA_LLM=5000

# Exportación.
MAX_EXPORT_BODY_BYTES=15728640
MAX_LONGITUD_VALOR_EXPORTACION=50000
MAX_LONGITUD_EVIDENCIA_EXPORTACION=8000

# Auditoría local. Solo incluye huella SHA-256 del fichero, no su contenido.
INCLUIR_HASH_DOCUMENTO_AUDITORIA=true

# Botón de apagado local desde la interfaz. Desactivado por defecto para reducir superficie.
PERMITIR_APAGADO_UI=false

# Imagen de Ollama. Para reproducibilidad máxima, sustituir por digest probado:
# OLLAMA_IMAGE=ollama/ollama@sha256:...
OLLAMA_IMAGE=ollama/ollama:0.21.2

# Gestionado por el instalador Windows. No editar manualmente.
# Valores posibles en modo local bloqueado: http://ollama:11434 o http://host.docker.internal:11434
PLUMA_OLLAMA_MODE=container
PLUMA_OLLAMA_URL=http://ollama:11434

# Lectura visual previa para imágenes JPG/PNG/TIFF/WebP sin capa textual.
# Usa el modelo base multimodal para transcribir texto visible antes de la
# extracción archivística estructurada.
MODELO_VISUAL_LECTURA=gemma4:e2b
PLUMA_LECTURA_VISUAL_PREVIA=true
MAX_TRANSCRIPCION_VISUAL=12000
