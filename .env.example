# =============================================================================
# PlumA — variables de entorno
# -----------------------------------------------------------------------------
# Copia este fichero como .env y ajusta los valores según necesidad.
# Los valores por defecto funcionan para la mayoría de instalaciones.
# =============================================================================

# -----------------------------------------------------------------------------
# Modelo de IA
# -----------------------------------------------------------------------------
# Modelo base de Ollama a descargar la primera vez. Opciones recomendadas:
#   gemma4:e2b         equilibrio ligero/calidad, multimodal, por defecto
#   gemma4:e4b        mayor calidad, requiere más RAM
#   qwen2.5vl:7b      alternativa visual para documentos densos y tablas
#   gpt-oss:20b       máxima calidad, requiere GPU decente
MODELO_BASE=gemma4:e2b

# Nombre interno del modelo especializado que se crea a partir del Modelfile.
# No cambiar salvo que se quiera mantener varias versiones en paralelo.
MODELO_NOMBRE=pluma

# -----------------------------------------------------------------------------
# Rutas internas (dentro del contenedor)
# -----------------------------------------------------------------------------
MODELFILE_PATH=/app/Modelfile
DIR_ESQUEMAS=/app/schemas

# -----------------------------------------------------------------------------
# Red
# -----------------------------------------------------------------------------
# URL interna por la que la app llega a Ollama. No cambiar salvo despliegues
# personalizados.
OLLAMA_URL=http://ollama:11434

# Puerto en el que escucha la aplicación (host y contenedor).
PUERTO=8082

# -----------------------------------------------------------------------------
# Seguridad avanzada
# -----------------------------------------------------------------------------
# Mantener true salvo depuración. Ejecuta parsers PDF/DOCX/imagen en proceso hijo
# con timeout y, en Linux, límite de memoria.
USAR_SANDBOX_PARSERS=true
SANDBOX_TIMEOUT_SEGUNDOS=90
SANDBOX_MEMORIA_MB=1536

# Por defecto la app solo permite Ollama local: localhost, host.docker.internal
# o el servicio Docker "ollama". Activar esto puede enviar documentos a un
# endpoint remoto; úselo solo si asume esa transferencia.
ALLOW_REMOTE_OLLAMA=false

# Permite apagar el servidor local desde el botón de la interfaz.
# Mantener true para uso local. No exponga la aplicación en red sin autenticación.
PERMITIR_APAGADO_UI=true


# -----------------------------------------------------------------------------
# Contexto y longitud de salida
# -----------------------------------------------------------------------------
# Texto máximo extraído que puede incorporarse al prompt. Aumentarlo mejora el
# contexto disponible para documentos largos, pero incrementa memoria, latencia
# y consumo del modelo local.
MAX_LONGITUD_TEXTO_EXTRAIDO=800000

# Ventana de contexto y tokens máximos de respuesta para Ollama. Si el modelo
# elegido no soporta una ventana amplia, Ollama puede ignorar o ajustar este
# valor. Para descripciones ISAD(G) densas conviene usar modelos con contexto
# amplio.
OLLAMA_NUM_CTX=32768
OLLAMA_NUM_PREDICT=8192

# Límites internos de longitud de los valores devueltos por el modelo.
MAX_LONGITUD_VALOR_LLM=50000
MAX_LONGITUD_EVIDENCIA_LLM=4000
MAX_LONGITUD_ITEM_LISTA_LLM=5000

# Límites de exportación. Deben acompañar a los límites anteriores para que
# campos largos como título y alcance/contenido no fallen al descargar.
MAX_EXPORT_BODY_BYTES=15728640
MAX_LONGITUD_VALOR_EXPORTACION=50000
MAX_LONGITUD_EVIDENCIA_EXPORTACION=8000

# Imagen de Ollama. Para releases institucionales se recomienda fijar una versión
# o digest probado, por ejemplo ollama/ollama@sha256:...
OLLAMA_IMAGE=ollama/ollama:latest
