# =============================================================================
# PlumA — .env.example
# -----------------------------------------------------------------------------
# Copia este fichero a .env y ajusta los valores que necesites.
# Las variables comentadas tienen un valor por defecto razonable; descoméntalas
# solo si quieres cambiarlo.
#
# IMPORTANTE: en la release pública (perfil bundled-local-locked) las variables
# OLLAMA_URL, ALLOW_REMOTE_OLLAMA, ALLOW_NETWORK_EXPOSURE, PLUMA_STRICT_LOCAL,
# PERFIL y COMPOSE_PROFILES son ignoradas si se definen aquí: las elimina el
# instalador por seguridad. No tiene sentido configurarlas.
# =============================================================================

# -----------------------------------------------------------------------------
# Puerto en el que la aplicación escucha en localhost
# -----------------------------------------------------------------------------
PUERTO=8082

# -----------------------------------------------------------------------------
# Modelo base de Ollama
# -----------------------------------------------------------------------------
# Cambia este valor para usar otro modelo (gemma3:12b, qwen2.5:7b-instruct,
# llama3.1:8b, etc.). NO requiere reconstruir nada en Ollama: PlumA inyecta el
# system prompt en cada llamada desde schemas/pluma-runtime.yaml.
#
# El modelo debe existir en Ollama o poder descargarse en el perfil
# correspondiente. Para ver los modelos descargados: `ollama list`.
MODELO_BASE=gemma4:e2b

# -----------------------------------------------------------------------------
# Parámetros de inferencia que pisan al YAML de runtime
# -----------------------------------------------------------------------------
# El comportamiento del asistente (system prompt completo) y las opciones por
# defecto (temperature, top_p, top_k, repeat_penalty, num_ctx, stop) viven en
# schemas/pluma-runtime.yaml, no aquí.
#
# Las dos variables siguientes son las únicas que pisan al YAML desde .env.
# Útil si necesitas ajustar contexto/memoria sin tocar el YAML.

# Tamaño de contexto en tokens. Súbelo si trabajas con documentos largos y
# tu hardware lo permite; bájalo en máquinas modestas para acelerar.
#OLLAMA_NUM_CTX=8192

# Tokens máximos generados por respuesta.
#OLLAMA_NUM_PREDICT=4096

# -----------------------------------------------------------------------------
# Límites de procesamiento (router.py)
# -----------------------------------------------------------------------------
# Descomenta solo si necesitas ajustar los valores por defecto.

# Longitud máxima del texto extraído de un documento (caracteres).
#MAX_LONGITUD_TEXTO_EXTRAIDO=800000

# Permitir ruta híbrida (texto + imágenes) para PDFs cortos.
# Por defecto está desactivada porque consume más tokens y memoria.
#PLUMA_PDF_HIBRIDO_CON_IMAGENES=false

# -----------------------------------------------------------------------------
# Concurrencia y límites de API (api.py)
# -----------------------------------------------------------------------------

# Procesamientos simultáneos. En máquinas modestas, mantén 1.
#MAX_PROCESAMIENTOS_SIMULTANEOS=1

# Permitir apagar el servidor desde la interfaz web. Útil en despliegues
# unipersonales; desactívalo si varios usuarios comparten la instancia.
#PERMITIR_APAGADO_UI=false

# Incluir SHA-256 del documento procesado en la ficha técnica de auditoría.
# Recomendado para trazabilidad institucional.
#INCLUIR_HASH_DOCUMENTO_AUDITORIA=true

# -----------------------------------------------------------------------------
# Sandbox de parsers (parser_sandbox.py)
# -----------------------------------------------------------------------------
# El sandbox aísla el procesamiento de PDF/DOCX/imagen en un proceso hijo.
# NO lo desactives en producción. Esta variable solo está documentada para
# depuración local.
#USAR_SANDBOX_PARSERS=true
